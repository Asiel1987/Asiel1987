# =============================================================================
# Asiel Farm Shop API — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development          # 'development' | 'production' | 'test'
PORT=3001                     # HTTP port the API listens on

# ---------------------------------------------------------------------------
# PostgreSQL / Supabase
# ---------------------------------------------------------------------------
# Full connection string — works with Supabase Transaction Pooler or direct
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:your-supabase-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Redis connection URL. Supports redis:// and rediss:// (TLS)
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------------------------------------------------------
# Session / Cookies
# ---------------------------------------------------------------------------
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_byte_random_hex_string_here

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# The exact origin of your frontend (no trailing slash)
FRONTEND_URL=http://localhost:5173
# Public URL of the backend API — used for payment provider callbacks/webhooks (no trailing slash)
BACKEND_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Africa's Talking — OTP SMS
# ---------------------------------------------------------------------------
# Sandbox username is literally 'sandbox'. Swap for your live username in prod.
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-africastalking-api-key-here
# Sender ID registered on Africa's Talking dashboard (optional in sandbox)
AFRICASTALKING_SENDER_ID=AsielFarm

# ---------------------------------------------------------------------------
# Stripe — Card Payments
# ---------------------------------------------------------------------------
# Use sk_test_* in development, sk_live_* in production
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
# Webhook signing secret from the Stripe dashboard (for future webhook route)
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_secret

# ---------------------------------------------------------------------------
# Selcom — Tanzania Mobile Money Aggregator (TigoPesa, M-Pesa TZ, Airtel)
# ---------------------------------------------------------------------------
SELCOM_API_URL=https://apigw.selcommobile.com/v1
SELCOM_API_KEY=your-selcom-api-key-here
SELCOM_API_SECRET=your-selcom-api-secret-here
# Your Selcom vendor ID
SELCOM_VENDOR=your-selcom-vendor-id

# ---------------------------------------------------------------------------
# M-Pesa Kenya — Safaricom Daraja
# ---------------------------------------------------------------------------
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
# Business shortcode (till/paybill number)
MPESA_SHORTCODE=174379
# Lipa Na M-Pesa Online passkey from Daraja portal
MPESA_PASSKEY=your-mpesa-passkey
# Publicly reachable URL for STK push callbacks
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
# 'sandbox' or 'live'
MPESA_ENV=sandbox

# ---------------------------------------------------------------------------
# Open Exchange Rates — FX rates
# ---------------------------------------------------------------------------
# Sign up free at openexchangerates.org
OPENEXCHANGERATES_APP_ID=your-openexchangerates-app-id

# ---------------------------------------------------------------------------
# VFD / TRA Fiscal Receipts (NepTech)
# ---------------------------------------------------------------------------
# NepTech API base URL for Virtual Fiscal Device integration
VFD_API_URL=https://vfd.neptech.co.tz/api/vfd
VFD_USERNAME=your-vfd-username
VFD_PASSWORD=your-vfd-password
# Your company TIN and VRN registered with TRA
VFD_TIN=your-tra-tin
VFD_VRN=your-tra-vrn
VFD_SERIAL=your-vfd-serial-number

# ---------------------------------------------------------------------------
# Social Sign-In (Google + Apple)
# ---------------------------------------------------------------------------
# Google OAuth 2.0
# Create at https://console.cloud.google.com > APIs & Services > Credentials
# Create an "OAuth 2.0 Client ID" for a Web Application.
# Add your frontend origin to "Authorized JavaScript Origins".
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Apple Sign In
# Create a Services ID at https://developer.apple.com > Certificates, IDs & Profiles > Identifiers
# Register your domain and Return URLs under the Services ID configuration.
# APPLE_CLIENT_ID is the Services ID (e.g. com.asiel.farm.web — NOT the App Bundle ID)
APPLE_CLIENT_ID=com.asiel.farm.web

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# Generate keys once: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:hello@asiel.farm
